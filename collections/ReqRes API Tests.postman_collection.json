    {
      "name": "Get All Users",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Response has data array\", function () {\r",
              "    let jsonData = pm.response.json();\r",
              "    pm.expect(jsonData.data).to.be.an(\"array\");\r",
              "});\r",
              "\r",
              "\r",
              "pm.test(\"Page number is 1\", function () {\r",
              "    let jsonData = pm.response.json();\r",
              "    pm.expect(jsonData.page).to.eql(1);\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "x-api-key",
            "value": "{{api_key}}",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{base_url}}/api/users?page=1",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "users"
          ],
          "query": [
            {
              "key": "page",
              "value": "1"
            }
          ]
        }
      },
      "response": []
